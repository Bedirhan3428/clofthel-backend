{
  "expo": {
    "name": "Clofthel",
    "slug": "Clofthel",
    "scheme": "clofthel",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/iconMain.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/iconMain.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/iconMain.jpg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bedirhan.clofthel",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ]
  }
}
